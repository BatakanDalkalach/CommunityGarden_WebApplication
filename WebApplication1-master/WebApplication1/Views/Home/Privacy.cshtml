@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container py-5">
    <div class="row">
        <div class="col-lg-8 mx-auto">
            <h1 class="display-4 mb-4">@ViewData["Title"]</h1>
            
            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="h5 mb-3">Information We Collect</h3>
                    <p>At Community Garden Management System, we collect only the information necessary to provide our services:</p>
                    <ul>
                        <li>Member registration information (name, email, contact details)</li>
                        <li>Garden plot assignments and preferences</li>
                        <li>Harvest records and garden activity data</li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="h5 mb-3">How We Use Your Information</h3>
                    <p>Your information is used exclusively for:</p>
                    <ul>
                        <li>Managing your garden plot assignments</li>
                        <li>Coordinating community garden activities</li>
                        <li>Communicating important updates and maintenance schedules</li>
                        <li>Tracking harvest records for community reports</li>
                    </ul>
                </div>
            </div>

            <div class="card shadow-sm mb-4">
                <div class="card-body">
                    <h3 class="h5 mb-3">Data Security</h3>
                    <p>We implement appropriate security measures to protect your personal information against unauthorized access, alteration, disclosure, or destruction.</p>
                </div>
            </div>

            <div class="card shadow-sm">
                <div class="card-body">
                    <h3 class="h5 mb-3">Contact Us</h3>
                    <p>If you have any questions about this Privacy Policy, please contact us through the community garden office.</p>
                </div>
            </div>
        </div>
    </div>
</div>
