@model WebApplication1.Models.GardenPlot
@{
    ViewData["Title"] = "Add New Plot";
}

<article class="cgms-form-container">
    <style>
        .cgms-form-container { background: linear-gradient(135deg, #e0f2fe, #fff); padding: 2.5rem 1rem; min-height: 100vh; }
        .cgms-form-card { max-width: 820px; margin: 0 auto; background: white; border-radius: 1.2rem; overflow: hidden; box-shadow: 0 8px 32px rgba(0,0,0,0.1); }
        .cgms-form-header { background: #0ea5e9; padding: 2.8rem; text-align: center; color: white; }
        .cgms-form-icon { font-size: 3.5rem; margin-bottom: 0.8rem; }
        .cgms-form-heading { margin: 0; font-size: 2.2rem; font-weight: 900; }
        .cgms-form-subhead { margin: 0.6rem 0 0; font-size: 1.1rem; opacity: 0.92; }
        .cgms-form-main { padding: 2.8rem; }
        .cgms-section-sep { text-align: center; margin: 2.5rem 0 2rem; position: relative; }
        .cgms-section-sep::before { content: ''; position: absolute; top: 50%; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, transparent, #0ea5e9, transparent); }
        .cgms-section-label { position: relative; background: white; padding: 0 1.5rem; color: #0ea5e9; font-weight: 800; font-size: 1.15rem; }
        .cgms-input-group { margin-bottom: 1.8rem; }
        .cgms-label-text { display: block; font-weight: 700; margin-bottom: 0.6rem; color: #111827; }
        .cgms-input-field { width: 100%; padding: 1rem; border: 2px solid #d1d5db; border-radius: 0.8rem; font-size: 1.05rem; }
        .cgms-input-field:focus { outline: none; border-color: #0ea5e9; box-shadow: 0 0 0 3px rgba(14, 165, 233, 0.1); }
        .cgms-hint-text { display: block; margin-top: 0.4rem; color: #6b7280; font-size: 0.9rem; }
        .cgms-two-col { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.8rem; }
        .cgms-checkbox-wrap { background: #f3f4f6; padding: 1.3rem; border-radius: 0.8rem; display: flex; align-items: center; gap: 1rem; }
        .cgms-checkbox-input { width: 24px; height: 24px; }
        .cgms-checkbox-label { margin: 0; font-weight: 600; font-size: 1.05rem; }
        .cgms-button-group { display: grid; grid-template-columns: 1fr 2fr; gap: 1.2rem; margin-top: 2.5rem; padding-top: 2rem; border-top: 2px solid #e5e7eb; }
        .cgms-btn { padding: 1.2rem; text-align: center; border-radius: 0.8rem; font-weight: 800; font-size: 1.1rem; cursor: pointer; }
        .cgms-btn-cancel { background: #9ca3af; color: white; text-decoration: none; }
        .cgms-btn-cancel:hover { background: #6b7280; color: white; }
        .cgms-btn-submit { background: #10b981; color: white; border: none; }
        .cgms-btn-submit:hover { background: #059669; }
    </style>

    <div class="container">
        <div class="cgms-form-card">
            <header class="cgms-form-header">
                <div class="cgms-form-icon">🌱</div>
                <h1 class="cgms-form-heading">Create New Garden Plot</h1>
                <p class="cgms-form-subhead">Enter plot information below</p>
            </header>
            
            <form asp-action="AddNew" method="post" class="cgms-form-main">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                
                <div class="cgms-section-sep">
                    <span class="cgms-section-label">📍 Plot Identification</span>
                </div>
                
                <div class="cgms-input-group">
                    <label asp-for="PlotDesignation" class="cgms-label-text"></label>
                    <input asp-for="PlotDesignation" class="cgms-input-field" placeholder="Example: A001" />
                    <span class="cgms-hint-text">Format: One letter + three digits</span>
                    <span asp-validation-for="PlotDesignation" class="text-danger"></span>
                </div>
                
                <div class="cgms-section-sep">
                    <span class="cgms-section-label">📏 Physical Properties</span>
                </div>
                
                <div class="cgms-two-col">
                    <div class="cgms-input-group">
                        <label asp-for="SquareMeters" class="cgms-label-text"></label>
                        <input asp-for="SquareMeters" type="number" step="0.1" class="cgms-input-field" />
                        <span class="cgms-hint-text">Range: 5-100 m²</span>
                        <span asp-validation-for="SquareMeters" class="text-danger"></span>
                    </div>
                    
                    <div class="cgms-input-group">
                        <label asp-for="SoilType" class="cgms-label-text"></label>
                        <select asp-for="SoilType" class="cgms-input-field">
                            <option value="Loamy">Loamy</option>
                            <option value="Sandy">Sandy</option>
                            <option value="Clay">Clay</option>
                            <option value="Silty">Silty</option>
                            <option value="Peaty">Peaty</option>
                            <option value="Chalky">Chalky</option>
                        </select>
                        <span asp-validation-for="SoilType" class="text-danger"></span>
                    </div>
                </div>
                
                <div class="cgms-section-sep">
                    <span class="cgms-section-label">💰 Financial Details</span>
                </div>
                
                <div class="cgms-two-col">
                    <div class="cgms-input-group">
                        <label asp-for="YearlyRentalFee" class="cgms-label-text"></label>
                        <input asp-for="YearlyRentalFee" type="number" step="0.01" class="cgms-input-field" />
                        <span asp-validation-for="YearlyRentalFee" class="text-danger"></span>
                    </div>
                    
                    <div class="cgms-input-group">
                        <label asp-for="LastMaintenanceDate" class="cgms-label-text"></label>
                        <input asp-for="LastMaintenanceDate" type="date" class="cgms-input-field" />
                        <span asp-validation-for="LastMaintenanceDate" class="text-danger"></span>
                    </div>
                </div>
                
                <div class="cgms-section-sep">
                    <span class="cgms-section-label">⚙️ Features</span>
                </div>
                
                <div class="cgms-input-group">
                    <div class="cgms-checkbox-wrap">
                        <input asp-for="WaterAccessAvailable" type="checkbox" class="cgms-checkbox-input" />
                        <label asp-for="WaterAccessAvailable" class="cgms-checkbox-label">Water access available at this location</label>
                    </div>
                </div>
                
                <div class="cgms-input-group">
                    <div class="cgms-checkbox-wrap">
                        <input asp-for="IsOccupied" type="checkbox" class="cgms-checkbox-input" />
                        <label asp-for="IsOccupied" class="cgms-checkbox-label">Mark plot as currently occupied</label>
                    </div>
                </div>
                
                <div class="cgms-input-group">
                    <label asp-for="AssignedGardenerId" class="cgms-label-text">Member Assignment (Optional)</label>
                    <select asp-for="AssignedGardenerId" class="cgms-input-field" asp-items="ViewBag.MemberOptions">
                        <option value="">-- No assignment --</option>
                    </select>
                    <span asp-validation-for="AssignedGardenerId" class="text-danger"></span>
                </div>
                
                <nav class="cgms-button-group">
                    <a asp-action="Index" class="cgms-btn cgms-btn-cancel">Cancel</a>
                    <button type="submit" class="cgms-btn cgms-btn-submit">🌱 Create Plot</button>
                </nav>
            </form>
        </div>
    </div>
</article>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
